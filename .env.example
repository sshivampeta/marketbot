# App
NODE_ENV=development

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Deployed engine URL (used by scheduler + web build in CI)
ENGINE_URL=https://marketbot-engine.<your-subdomain>.workers.dev

# Data ingestion (public/free first)
SEC_USER_AGENT=your-email@example.com

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Engine
ENGINE_PORT=8787
ENGINE_URL=http://localhost:8787
